<%- include('../includes/head') %>
<%- include('../includes/navigation') %>
<main class="cart-page">
  <h1>Your Cart</h1>

  <% if (!products || products.length === 0) { %>
    <p>Your cart is empty. Add a product from the shop to see it here.</p>
  <% } else { %>
    <table class="cart-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(item => { %>
          <tr>
            <td><%= item.productData.title %></td>
            <td>$<%= item.productData.price %></td>
            <td><%= item.qty %></td>
            <td>$<%= (+item.productData.price * item.qty).toFixed(2) %></td>
            <td>
              <form action="/cart-delete" method="POST" class="cart-delete-form">
                <input type="hidden" name="productId" value="<%= item.productData.id %>">
                <button type="submit" class="delete-button">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</main>
<%- include('../includes/end') %>
