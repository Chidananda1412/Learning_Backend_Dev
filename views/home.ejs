<%- include('includes/header', { pageTitle: pageTitle }) %>

            <section class="hero">
                <div class="container hero-inner">
                    <div class="hero-content">
                        <h1>Welcome to MyApp</h1>
                        <p>Fast, simple, and responsive starter homepage for your Node.js app.</p>
                        <div class="hero-actions">
                            <a class="btn primary" href="/admin">Browse Products</a>
                            <a class="btn" href="/admin">Learn More</a>
                        </div>
                    </div>
                    <div class="hero-illustration" aria-hidden="true">
                        <div class="phone-mock"></div>
                    </div>
                </div>
            </section>

            <section class="features container">
                <article class="feature">
                    <h3>Responsive</h3>
                    <p>Layouts that work across phones, tablets, and desktops.</p>
                </article>
                <article class="feature">
                    <h3>Lightweight</h3>
                    <p>Minimal CSS and semantic HTML for fast load times.</p>
                </article>
                <article class="feature">
                    <h3>Easy to Extend</h3>
                    <p>Plug into your existing Node.js routes and templates.</p>
                </article>
            </section>

            <section class="cards container">
                <div class="card">
                    <h4>Product A</h4>
                    <p>Short description of Product A.</p>
                    <a class="btn" href="/admin">Manage</a>
                </div>
                <div class="card">
                    <h4>Product B</h4>
                    <p>Short description of Product B.</p>
                    <a class="btn" href="/admin">Manage</a>
                </div>
                <div class="card">
                    <h4>Product C</h4>
                    <p>Short description of Product C.</p>
                    <a class="btn" href="/admin">Manage</a>
                </div>
            </section>

            <section class="container">
                <h3>Add Product</h3>
                <form action="/admin/products/add-product" method="post" class="product-form">
                    <input class="form-input" type="text" name="title" placeholder="Title" required />
                    <input class="form-input" type="number" name="price" placeholder="Price" required />
                    <button class="btn primary" type="submit">Add</button>
                </form>
            </section>

            <section class="container">
                <h3>Dynamic Products</h3>
                <% if (products && products.length > 0) { %>
                    <ul class="dynamic-products">
                    <% products.forEach(function(p){ %>
                        <li><strong><%= p.title %></strong> — $<%= p.price %></li>
                    <% }) %>
                    </ul>
                <% } else { %>
                    <p>No products yet. Go to <a href="/admin">Admin</a> to add some.</p>
                <% } %>
            </section>

<%- include('includes/footer') %>
